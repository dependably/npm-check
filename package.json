{
  "name": "@moonlitlabs/npm-check",
  "version": "1.5.0",
  "description": "A comprehensive tool for validating, migrating, and updating npm package-lock.json files across versions 1, 2, and 3.",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "npm-check": "bin/cli.js"
  },
  "files": [
    "src/",
    "bin/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "setup:hooks": "git config core.hooksPath .githooks",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config=jest.config.mjs",
    "test:unit": "npm test -- --testPathPattern=tests/unit",
    "test:integration": "INTEGRATION_TESTS=1 npm test -- --testPathPattern=tests/integration --runInBand",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:coverage": "npm test -- --coverage",
    "docker:build": "docker-compose -f tests/integration/docker/docker-compose.yml build",
    "docker:test:node18-npm9": "docker-compose -f tests/integration/docker/docker-compose.yml run --rm test-node18-npm9",
    "docker:test:node18-npm10": "docker-compose -f tests/integration/docker/docker-compose.yml run --rm test-node18-npm10",
    "docker:test:node20": "docker-compose -f tests/integration/docker/docker-compose.yml run --rm test-node20-npm10",
    "docker:test:node22": "docker-compose -f tests/integration/docker/docker-compose.yml run --rm test-node22-npm10",
    "docker:test:all": "docker-compose -f tests/integration/docker/docker-compose.yml up --abort-on-container-exit",
    "lint": "eslint .",
    "sbom": "cyclonedx-npm --output-format json --output-file sbom.json",
    "sbom:prod": "cyclonedx-npm --omit dev --output-format json --output-file sbom-prod.json",
    "prepublishOnly": "npm run test && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mhiland/npm-check.git"
  },
  "homepage": "https://github.com/mhiland/npm-check#readme",
  "bugs": {
    "url": "https://github.com/mhiland/npm-check/issues"
  },
  "keywords": [
    "npm",
    "package-lock",
    "npm-package-lock",
    "validator",
    "migrator",
    "updater",
    "lockfile",
    "package-lock.json",
    "integrity",
    "hash",
    "sha512",
    "node-modules"
  ],
  "author": {
    "name": "MHiland",
    "email": "michael@moonlitlabs.ca",
    "url": "https://github.com/mhiland"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/preset-env": "7.28.6",
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@eslint/js": "^10.0.1",
    "babel-jest": "30.2.0",
    "eslint": "10.5.0",
    "globals": "^17.6.0",
    "jest": "29.7.0",
    "sonarqube-scanner": "^3.5.0"
  },
  "overrides": {
    "@babel/plugin-transform-modules-systemjs": "7.29.7",
    "js-yaml": "4.2.0",
    "picomatch": "4.0.4",
    "glob": {
      "minimatch": "3.1.5",
      "brace-expansion": "1.1.15"
    },
    "test-exclude": {
      "minimatch": "3.1.5",
      "brace-expansion": "1.1.15"
    }
  }
}
