#!/bin/bash

# Pre-commit hook for npm-check (tracked; installed via the package.json
# "prepare" script, which points git's core.hooksPath at .githooks/).
# Gates a commit on: ESLint, npm-check's own lockfile validation (dogfooding),
# and a fast test subset (advisory only).

echo "🔍 Running pre-commit checks..."

if ! command -v npm &> /dev/null; then
  echo "❌ npm is not installed"
  exit 1
fi

ROOT="$(git rev-parse --show-toplevel)"

# 1. ESLint — hard gate
echo "📝 Running ESLint..."
npm run lint
if [ $? -ne 0 ]; then
  echo "❌ ESLint found issues. Fix them before committing."
  exit 1
fi

# 2. npm-check self-validation — hard gate (dogfood our own validator on our
#    own lockfile). Offline, fast, deterministic.
if [ -f "$ROOT/package-lock.json" ]; then
  echo "🔒 Validating package-lock.json with npm-check..."
  node "$ROOT/bin/cli.js" validate "$ROOT/package-lock.json" > /dev/null
  if [ $? -ne 0 ]; then
    echo "❌ npm-check validation failed. Run \`npm-check validate package-lock.json\` to see why,"
    echo "   or \`npm-check fix --write\` to repair structural issues."
    exit 1
  fi
fi

# 3. Fast test subset — advisory only (never blocks)
echo "⚡ Running fast test validation..."
npm test -- --testPathPattern="validator|integrity" --maxWorkers=1 2>/dev/null
if [ $? -ne 0 ]; then
  echo "⚠️  Some tests failed. Review the output above."
  echo "💡 You can run 'npm test' for the full test suite."
  # Don't exit 1 here — allow commit with warning
fi

echo "✅ Pre-commit checks completed!"
exit 0
